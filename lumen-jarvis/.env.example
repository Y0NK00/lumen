# Copy this file to `.env` in THIS folder (same directory as `lumen-jarvis.py`).
# Jarvis loads `.env` from that folder even if you start Python from elsewhere.

# Lumen server (same API as the PWA)
LUMEN_SERVER_URL=http://tower.local:7747
LUMEN_EMAIL=your-email@example.com
LUMEN_PASSWORD=your-password

# Groq — Whisper STT (https://console.groq.com)
GROQ_API_KEY=

# Hotkey — hold while speaking, release to send
JARVIS_HOTKEY=ctrl+space

# Edge TTS voice
JARVIS_VOICE=en-US-GuyNeural

# HUD (local browser)
JARVIS_HUD_HOST=127.0.0.1
JARVIS_HUD_PORT=9777
JARVIS_OPEN_BROWSER=1
