# ──────────────────────────────────────────────────────────────
# Lumen Server Configuration
# Copy this file to `.env` and fill in all REQUIRED values.
# DO NOT commit `.env` (it is gitignored).
# ──────────────────────────────────────────────────────────────

# ── REQUIRED: Core ──

# Claude API key. Get from: https://console.anthropic.com → Settings → API Keys
# IMPORTANT: Set a monthly spending limit on console.anthropic.com as a safety net.
ANTHROPIC_API_KEY=sk-ant-api03-...

# JWT signing secret. Generate with: openssl rand -hex 64
# If leaked, rotate immediately (all users will be logged out).
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64

# Session cookie secret. Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# App-level encryption key for oauth tokens in DB. Generate with: openssl rand -hex 32
# DO NOT change this after initial setup or existing encrypted fields become unreadable.
ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ── REQUIRED: Admin Bootstrap ──
# On first startup, server creates this admin user if no users exist.
# Change the password via the UI after first login.
ADMIN_BOOTSTRAP_EMAIL=will@example.com
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_pick_a_strong_password
ADMIN_BOOTSTRAP_DISPLAY_NAME=Will

# ── REQUIRED: Server ──

PORT=7747
EXTENSION_WS_PORT=7745
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# Data directory — where SQLite DB and attachments live.
# In Docker, mount a volume here.
DATA_DIR=/data

# Public URL where users reach this server (for email links, OAuth callbacks).
# Example: https://lumen.yourdomain.com
PUBLIC_URL=https://lumen.example.com

# ── RECOMMENDED: Email (for password resets, budget alerts, welcome emails) ──

# Get from https://resend.com → API Keys. Free tier: 100 emails/day.
RESEND_API_KEY=re_...

# Must be on a domain you've verified in Resend. Example: noreply@yourdomain.com
FROM_EMAIL=noreply@example.com

# ── REQUIRED: Ollama (local embeddings) ──

OLLAMA_BASE_URL=http://10.0.0.22:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── OPTIONAL: Per-user OAuth (Google Drive, Calendar) ──
# Each user connects their own Google account via the UI; these are the shared app credentials.
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an "OAuth 2.0 Client ID" of type "Web application".
# Authorized redirect URI: ${PUBLIC_URL}/api/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── OPTIONAL: Web search tools (for Claude to search the web) ──

# Brave Search API — free tier: 2000 queries/month. https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Tavily — LLM-optimized search. https://tavily.com/
TAVILY_API_KEY=

# ── OPTIONAL: Monitoring + Alerts ──

# Sentry (error tracking). https://sentry.io (free tier available)
SENTRY_DSN=

# Discord webhook for system alerts (budget exceeded, errors, extension offline).
# Server → Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ── Claude Model Pricing (USD per 1M tokens) ──
# Defaults match published rates as of 2026-04.
# Override only if Anthropic changes pricing and you need to update without redeploy.
PRICE_SONNET_INPUT=3.00
PRICE_SONNET_OUTPUT=15.00
PRICE_SONNET_CACHE_READ=0.30
PRICE_SONNET_CACHE_WRITE=3.75
PRICE_OPUS_INPUT=15.00
PRICE_OPUS_OUTPUT=75.00
PRICE_HAIKU_INPUT=1.00
PRICE_HAIKU_OUTPUT=5.00

# ── Security ──

# Comma-separated origins allowed to call the API (for CORS).
# Include your Cloudflare Tunnel URL and localhost for dev.
CORS_ORIGINS=https://lumen.example.com,http://localhost:5173,http://localhost:7747

# Rate limit tuning (per user, per minute)
RATE_LIMIT_MESSAGES_PER_MIN=60
RATE_LIMIT_API_PER_MIN=600

# Session lifetime
JWT_EXPIRES_IN=7d
REFRESH_WINDOW=1d
