{
    "name":  "lumen",
    "version":  "1.0.0",
    "description":  "Lumen Ã¢â‚¬â€ Your private AI companion, running entirely on your own hardware.",
    "main":  "main.js",
    "scripts":  {
                    "start":  "electron .",
                    "build":  "electron-builder --win",
                    "dev:vite":  "vite",
                    "build:vite":  "vite build",
                    "type-check":  "tsc --noEmit",
                    "dev:electron:v2":  "wait-on tcp:5173 \u0026\u0026 cross-env LUMEN_V2=true electron .",
                    "dev:v2":  "concurrently -k \"npm:dev:vite\" \"npm:dev:electron:v2\""
                },
    "devDependencies":  {
                            "electron":  "^28.3.3",
                            "electron-builder":  "^24.13.3"
                        },
    "build":  {
                  "appId":  "com.lumen.ai",
                  "productName":  "Lumen",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "win":  {
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ],
                              "icon":  "assets/icon.ico"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true
                           }
              },
    "dependencies":  {
                         "electron-oauth2":  "^3.0.0",
                         "googleapis":  "^171.4.0"
                     }
}