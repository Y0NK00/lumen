{
    "name": "lumen",
    "version": "1.0.0",
    "description": "Lumen - Your private AI companion, running entirely on your own hardware.",
    "main": "main.js",
    "scripts": {
        "dev": "concurrently -k \"npm:server\" \"npm:pwa\" \"npm:electron\"",
        "server": "npm run dev --prefix lumen-server",
        "pwa": "npm run dev --prefix lumen-pwa",
        "electron": "wait-on tcp:5173 tcp:7747 && cross-env LUMEN_V2=true electron .",
        "build": "npm run build --prefix lumen-pwa && electron-builder --win",
        "start": "electron ."
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^28.3.3",
        "electron-builder": "^24.13.3",
        "wait-on": "^9.0.5"
    },
    "build": {
        "appId": "com.lumen.ai",
        "productName": "Lumen",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "assets/**",
            "lumen-pwa/dist/**",
            "node_modules/**"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": ["x64"]
                }
            ],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    },
    "dependencies": {
        "googleapis": "^171.4.0",
        "node-cron": "^4.2.1",
        "ws": "^8.20.0"
    }
}
